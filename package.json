{
  "name": "ad-agent",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "trap 'kill $(jobs -p) 2>/dev/null' EXIT; /opt/homebrew/bin/python3.11 -m uvicorn freepik_server:app --host 0.0.0.0 --port 8890 & vite",
    "dev:vite": "vite",
    "dev:freepik": "/opt/homebrew/bin/python3.11 -m uvicorn freepik_server:app --host 0.0.0.0 --port 8890",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "antd": "^6.3.1",
    "framer-motion": "^12.35.2",
    "html-to-image": "^1.11.13",
    "idb-keyval": "^6.2.2",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.15",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
